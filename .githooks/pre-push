#!/usr/bin/env bash
# Pre-push secret scan. Blocks push if suspicious tokens found.
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 Pre-push security scan..."

FAIL=0

# 1) Files matching .env* (except .env.example) must NOT be tracked
TRACKED_ENV=$(git ls-files | grep -E '(^|/)\.env($|\.)' | grep -v '\.env\.example$' || true)
if [ -n "$TRACKED_ENV" ]; then
  echo -e "${RED}❌ Tracked .env files found (must be gitignored):${NC}"
  echo "$TRACKED_ENV"
  FAIL=1
fi

# 2) Scan all tracked files for secret patterns
PATTERNS=(
  # Telegram bot tokens: digits:hash
  '[0-9]{8,12}:[A-Za-z0-9_-]{30,}'
  # AWS access keys
  'AKIA[0-9A-Z]{16}'
  # Upstash REST tokens
  'gQAAAA[A-Za-z0-9_-]{40,}'
  # Generic API key patterns
  'sk-[a-zA-Z0-9]{20,}'
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'ghs_[a-zA-Z0-9]{36}'
  # Private keys
  '-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----'
  # JWT
  'eyJ[A-Za-z0-9_-]{20,}\.eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}'
)

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(git ls-files | xargs grep -lE "$pattern" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    # Filter out .env.example (allowed to mention patterns in comments) and this hook itself
    REAL=$(echo "$MATCHES" | grep -v -E '\.env\.example$|\.githooks/' || true)
    if [ -n "$REAL" ]; then
      echo -e "${RED}❌ Secret pattern detected: ${pattern}${NC}"
      echo "   in files:"
      echo "$REAL" | sed 's/^/     /'
      FAIL=1
    fi
  fi
done

# 3) Warn if .env.local exists and somehow ended up staged
if git ls-files --cached | grep -qE '\.env\.local$'; then
  echo -e "${RED}❌ .env.local is staged for commit!${NC}"
  FAIL=1
fi

if [ $FAIL -eq 1 ]; then
  echo ""
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}❌ PUSH BLOCKED: secrets detected${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo -e "${YELLOW}Fix the files above, then push again.${NC}"
  echo -e "${YELLOW}To bypass (NOT recommended): git push --no-verify${NC}"
  exit 1
fi

echo -e "${GREEN}✓ No secrets detected${NC}"
echo -e "${GREEN}✓ Push allowed${NC}"
exit 0

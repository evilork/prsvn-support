# ════════════════════════════════════════════════════════════════════════════
# Support bot env vars
# Add to .env.local for local dev AND to Vercel Project Settings for deploy
# ════════════════════════════════════════════════════════════════════════════

# Bot token from @BotFather
SUPPORT_BOT_TOKEN=

# Random hex string for webhook validation — generate with: openssl rand -hex 32
SUPPORT_BOT_WEBHOOK_SECRET=

# Comma-separated Telegram user IDs allowed to operate the bot.
# These users receive forwarded client tickets in their DM with the bot
# and reply to clients via Reply on a client message.
# Example: SUPPORT_ADMIN_USER_IDS=6944217115,123456789
SUPPORT_ADMIN_USER_IDS=

# Upstash Redis — can be the same instance as main project (we use support:* prefix)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional overrides — have sane defaults
SITE_URL=https://proxysvpn.com
DASHBOARD_URL=https://proxysvpn.com/dashboard
GUIDE_URL=https://proxysvpn.com/guide
MAIN_BOT_URL=https://t.me/proxysvpn_bot
